{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/backblaze-labs/genblaze/schemas/events/v1/pipeline-started.schema.json",
  "title": "PipelineStartedEvent",
  "description": "Emitted once at the start of a pipeline run.",
  "type": "object",
  "required": ["type", "timestamp", "run_id", "total_steps"],
  "properties": {
    "type": {
      "const": "pipeline.started",
      "description": "Discriminator tag identifying the event variant."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "When this event was created (UTC)."
    },
    "run_id": {
      "type": "string",
      "description": "Run identifier this event belongs to."
    },
    "total_steps": {
      "type": "integer",
      "minimum": 0,
      "description": "Total number of steps in the pipeline."
    },
    "message": {
      "type": ["string", "null"],
      "default": null,
      "description": "Pipeline name, if named."
    }
  },
  "additionalProperties": false
}
