{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/backblaze-labs/genblaze/schemas/events/v1/agent-completed.schema.json",
  "title": "AgentCompletedEvent",
  "description": "Emitted once when the agent loop terminates (pass, fail, or max-iters).",
  "type": "object",
  "required": ["type", "timestamp", "passed", "iterations"],
  "properties": {
    "type": {
      "const": "agent.completed",
      "description": "Discriminator tag identifying the event variant."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "When this event was created (UTC)."
    },
    "passed": {
      "type": "boolean",
      "description": "Whether the final iteration's evaluation passed."
    },
    "iterations": {
      "type": "integer",
      "minimum": 0,
      "description": "Total number of iterations executed."
    },
    "total_cost_usd": {
      "type": ["number", "null"],
      "default": null,
      "description": "Summed cost across all iterations, if tracked."
    }
  },
  "additionalProperties": false
}
